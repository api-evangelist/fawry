          "name": "Create a Charge",
          "request": {
            "name": "Create a Charge",
            "description": {
              "content": "Create a payment request. Used both for card / e-wallet payments and\nfor generating a FawryPay reference number that the customer can pay\nat a Fawry retail POS, ATM, or banking channel. The `paymentMethod`\nfield selects the channel (e.g. `PayAtFawry`, `CARD`, `MWALLET`).\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "ECommerceWeb",
                "Fawry",
                "payments",
                "charge"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantCode\": \"<string>\",\n  \"merchantRefNum\": \"<string>\",\n  \"paymentMethod\": \"<string>\",\n  \"customerMobile\": \"<string>\",\n  \"customerEmail\": \"<email>\",\n  \"amount\": \"<float>\",\n  \"description\": \"<string>\",\n  \"language\": \"<string>\",\n  \"chargeItems\": [\n    {\n      \"itemId\": \"<string>\",\n      \"description\": \"<string>\",\n      \"price\": \"<float>\",\n      \"quantity\": \"<float>\"\n    },\n    {\n      \"itemId\": \"<string>\",\n      \"description\": \"<string>\",\n      \"price\": \"<float>\",\n      \"quantity\": \"<float>\"\n    }\n  ],\n  \"signature\": \"<string>\",\n  \"customerProfileId\": \"<string>\",\n  \"customerName\": \"<string>\",\n  \"currencyCode\": \"EGP\",\n  \"paymentExpiry\": \"<long>\",\n  \"orderWebHookUrl\": \"<uri>\"\n}",
