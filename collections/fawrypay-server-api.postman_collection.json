        {
          "id": "6c245c8c-b749-4827-a7ca-91fce1f32516",
          "name": "Get Payment Status",
          "request": {
            "name": "Get Payment Status",
            "description": {
              "content": "Pull the current status of a FawryPay order by merchant code and\nmerchant reference number. Equivalent payload is also delivered via\nthe server notification v2 push webhook configured per merchant.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "ECommerceWeb",
                "Fawry",
                "payments",
                "status",
                "v2"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "merchantCode",
                  "value": "<string>",
                  "description": "(Required) "
                },
                {
                  "disabled": false,
                  "key": "merchantRefNumber",
                  "value": "<string>",
                  "description": "(Required) "
                },
                {
                  "disabled": false,
                  "key": "signature",
                  "value": "<string>",
                  "description": "(Required) SHA-256 hash of `merchantCode + merchantRefNumber + secureKey`."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
            {
              "id": "e30d2a23-a9b0-476a-a800-e8883790ca18",
