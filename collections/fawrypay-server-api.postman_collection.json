  "info": {
    "_postman_id": "2859ca61-3776-4e1d-8938-8ee6e145da3a",
    "name": "FawryPay Server API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Server-to-server REST API for FawryPay, the e-payment platform operated by\nFawry (Egypt). Supports card payments (incl. 3DS), e-wallet payments, payment\nrequests using a FawryPay reference number, refunds, payment status queries,\nand cancellation of unpaid orders. Authentication is via a per-merchant\n`merchantCode` plus a SHA-256 signature computed from the request body and a\nshared `secureKey`.\n\n\nContact Support:\n Name: FawryPay Developer Support",
      "type": "text/plain"
    }
  }
